    <title>pytorch、numpy和list的求平方</title>
    <link href="http://yoursite.com/2019/07/18/pytorch%E3%80%81numpy%E5%92%8Clist%E7%9A%84%E6%B1%82%E5%B9%B3%E6%96%B9/"/>
